algoritmo "Algoritmo 005"
// Função : ler dois valores e somar
// Autor : Carlos vinicius
// Data : 16 / 04 / 2026
var
  n1 , n2 , s : inteiro
inicio
     escreva (" Informe o Primeiro Valor : ")
     leia (n1)
     escreva (" Informe o Segundo Valor : ")
     leia (n2)
     s <- n1 + n2
     escreval (" A soma entre " , n1 , " e " , n2 , " e igual a " , s)
fimalgoritmo
